{
  "arch": "mujoco",
  "n_layer_enc": 3,
  "n_layer_dec": 3,
  "d_model": 64,
  "timesteps": 500,
  "sampling_timesteps": 500,
  "loss_type": "l1",
  "beta_schedule": "cosine",
  "n_heads": 4,
  "mlp_hidden_times": 4,
  "kernel_size": 1,
  "padding_size": 0,
  "feature_size": 1,
  "seq_length": 128,
  "max_epochs": 12000,
  "base_lr": 1e-05,
  "batch_size": 128,
  "ema_decay": 0.995,
  "gradient_accumulate_every": 2,
  "patience": 3000,
  "seed": 2
}